def team_vote(game, voter_id, target_id):
    voter = next((p for p in game["players"] if p["id"] == voter_id), None)
    target = next((p for p in game["players"] if p["id"] == target_id), None)
    if not voter or not target:
        return False
    if voter["team"] == target["team"]:
        return False  # Нельзя голосовать против своей команды
    game["voters"][voter_id] = target_id
    return True

