def load_skills():
    if os.path.exists("skills.json"):
        try:
            with open("skills.json", "r", encoding="utf-8") as f:
                return json.load(f)
        except:
            return {}
    return {}

def save_skills(skills):
    try:
        with open("skills.json", "w", encoding="utf-8") as f:
            json.dump(skills, f, ensure_ascii=False, indent=2)
    except:
        pass

def add_exp(user_id, exp):
    skills = load_skills()
    uid = str(user_id)
    if uid not in skills:
        skills[uid] = {"exp": 0, "level": 1, "skills": {s: 0 for s in SKILLS}}
    skills[uid]["exp"] += exp
    # Повышение уровня каждые 100 exp
    new_level = 1 + skills[uid]["exp"] // 100
    if new_level > skills[uid]["level"]:
        skills[uid]["level"] = new_level
        return new_level
    save_skills(skills)
    return None

def upgrade_skill(user_id, skill_name):
    skills = load_skills()
    uid = str(user_id)
    if uid not in skills:
        return "❌ У вас нет опыта"
    if skill_name not in SKILLS:
        return "❌ Такого навыка нет"
    current = skills[uid]["skills"].get(skill_name, 0)
    cost = SKILLS[skill_name]["cost"] * (current + 1)
    if skills[uid]["exp"] < cost:
        return f"❌ Не хватает опыта. Нужно {cost}, у вас {skills[uid]['exp']}"
    skills[uid]["exp"] -= cost
    skills[uid]["skills"][skill_name] = current + 1
    save_skills(skills)
    return f"✅ Навык {skill_name} повышен до {current + 1} уровня"

