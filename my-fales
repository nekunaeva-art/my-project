RESOURCES = ["еда", "вода", "топливо", "лекарства", "боеприпасы", "инструменты", "книги", "развлечения"]

def init_economy():
    return {res: random.randint(10, 50) for res in RESOURCES}

def update_economy(economy, action, amount=1):
    if action == "consume":
        for res in RESOURCES:
            economy[res] = max(0, economy[res] - amount)
    elif action == "find":
        res = random.choice(RESOURCES)
        economy[res] += random.randint(1, 10)
    return economy

def trade(economy, from_res, to_res, amount):
    if economy[from_res] >= amount:
        economy[from_res] -= amount
        economy[to_res] += amount
        return True
    return False

