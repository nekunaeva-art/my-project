        p["skip_vote"] = False
    
    # Подсчёт голосов
    votes = {}
    for p in [p for p in game["players"] if p["alive"]]:
        pid = p["id"]
        if pid in game["voters"]:
            target_id = game["voters"][pid]
            votes[str(target_id)] = votes.get(str(target_id), 0) + 1
    
    if not votes:
        eliminated = random.choice(alive) if alive else None
    else:
        max_votes = max(votes.values())
        candidates = [uid for uid, v in votes.items() if v == max_votes]
        eliminated_id = random.choice(candidates)
        eliminated = next((p for p in alive if str(p["id"]) == eliminated_id), None)
        if eliminated is None and alive:
            eliminated = random.choice(alive)
    
    if eliminated:
        eliminated["alive"] = False
        send(chat_id, f"💀 *ВЫБЫЛ:* {eliminated['name']}")
    
    alive_after = [p for p in game["players"] if p["alive"]]
    if len(alive_after) <= 1:
        end_game(chat_id)
    else:
        game["round"] += 1
        game["reveal_index"] = 0
        game["stage"] = "playing"
        game["voters"] = {}
        game["round_event_triggered"] = False
        send(chat_id, f"🔁 Раунд {game['round']}. Следующий показ карт.")
        start_reveal(chat_id)

def end_game(chat_id):
    game = active_games.get(chat_id)
    if not game:
        return
    alive = [p for p in game["players"] if p["alive"]]
    winner = alive[0] if alive else None
    if winner:
        msg = f"🏆 *ПОБЕДИТЕЛЬ:* {winner['name']}!\n\n"
        if winner["is_bot"]:
            msg += "🤖 Бот оказался хитрее. Попробуй ещё раз!\n\n"
        else:
            msg += "🎉 Поздравляю! Ты победил!\n\n"
        
        threat_name = game["threat"]
        threat = THREATS_DATA.get(threat_name, {})
        survival = False
        if winner["profession"] in threat.get("counter_professions", []):
            survival = True
        elif any(item in winner["luggage"] for item in threat.get("counter_luggage", [])):
            survival = True
        
        msg += f"⚠️ Угроза: *{threat_name}*\n{threat.get('description', '')}\n\n"
        if survival:
            msg += "✅ *Ты выжил!*"
            moral_gain = 10
            add_exp(winner["id"], 100)
            update_ranking(winner["id"], True)
        else:
            msg += "❌ *Ты не справился...*"
            moral_gain = -5
            add_exp(winner["id"], 50)
            update_ranking(winner["id"], False)
        
        # Достижения
        new_ach = check_achievements(winner["id"], winner["name"])
        if new_ach:
            msg += f"\n🎖️ *Новые достижения:* " + ", ".join(new_ach)
        
        # Рейтинг
        rating = get_rating(winner["id"])
        if rating:
            msg += f"\n📊 *Рейтинг:* {rating}"
    else:
        msg = "💀 Все погибли. Ничья."
    
    send(chat_id, msg)
    del active_games[chat_id]

