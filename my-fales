def load_stats():
    if os.path.exists("bunker_stats.json"):
        try:
            with open("bunker_stats.json", "r", encoding="utf-8") as f:
                return json.load(f)
        except:
            return {}
    return {}

def save_stats(stats):
    try:
        with open("bunker_stats.json", "w", encoding="utf-8") as f:
            json.dump(stats, f, ensure_ascii=False, indent=2)
    except:
        pass

def update_stats(user_id, user_name, won, profession, threat_name, moral_gain):
    stats = load_stats()
    uid = str(user_id)
    if uid not in stats:
        stats[uid] = {"name": user_name, "games": 0, "wins": 0, "losses": 0, "professions": {}, "moral_total": 0, "achievements": []}
    s = stats[uid]
    s["games"] += 1
    if won:
        s["wins"] += 1
    else:
        s["losses"] += 1
    s["professions"][profession] = s["professions"].get(profession, 0) + 1
    s["moral_total"] += moral_gain
    save_stats(stats)

def check_achievements(user_id, user_name):
    stats = load_stats()
    uid = str(user_id)
    if uid not in stats:
        return []
    s = stats[uid]
    new_ach = []
    for ach in ACHIEVEMENTS:
        if ach not in s.get("achievements", []):
            if ach == "first_game" and s["games"] >= 1:
                new_ach.append(ach)
            elif ach == "first_win" and s["wins"] >= 1:
                new_ach.append(ach)
            elif ach == "survivor" and s["wins"] >= 10:
                new_ach.append(ach)
            elif ach == "lone_wolf" and s["wins"] >= 10:
                new_ach.append(ach)
    if new_ach:
        s["achievements"] = s.get("achievements", []) + new_ach
        save_stats(stats)
    return [ACHIEVEMENTS[a] for a in new_ach]

