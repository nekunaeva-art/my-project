def get_current_season():
    now = datetime.now()
    for season, dates in RANKING_SEASONS.items():
        start = datetime.strptime(dates["start"], "%Y-%m-%d")
        end = datetime.strptime(dates["end"], "%Y-%m-%d")
        if start <= now <= end:
            return season, dates["name"]
    return None, None

def update_ranking(user_id, win):
    season, season_name = get_current_season()
    if not season:
        return
    ranking_file = f"ranking_{season}.json"
    if os.path.exists(ranking_file):
        with open(ranking_file, "r", encoding="utf-8") as f:
            ranking = json.load(f)
    else:
        ranking = {}
    uid = str(user_id)
    if uid not in ranking:
        ranking[uid] = {"wins": 0, "games": 0, "rating": 1000}
    ranking[uid]["games"] += 1
    if win:
        ranking[uid]["wins"] += 1
        ranking[uid]["rating"] += 25
    else:
        ranking[uid]["rating"] -= 15
    with open(ranking_file, "w", encoding="utf-8") as f:
        json.dump(ranking, f, ensure_ascii=False, indent=2)

def get_rating(user_id):
    season, _ = get_current_season()
    if not season:
        return None
    ranking_file = f"ranking_{season}.json"
    if not os.path.exists(ranking_file):
        return None
    with open(ranking_file, "r", encoding="utf-8") as f:
        ranking = json.load(f)
    uid = str(user_id)
    return ranking.get(uid, {}).get("rating", 1000)

