def create_faction(faction_name, player):
    if faction_name not in FACTIONS:
        return None
    player["faction"] = faction_name
    player["faction_bonus_used"] = False
    return FACTIONS[faction_name]["bonus"]

def use_faction_bonus(game, player):
    if not player.get("faction") or player.get("faction_bonus_used"):
        return False
    faction = player["faction"]
    if faction == "Инженеры":
        player["skip_vote"] = False  # Может игнорировать поломку
        return "🔧 Инженер починил генератор!"
    elif faction == "Медики":
        for p in game["players"]:
            p["doomed"] = 0
        return "💊 Медики вылечили всех!"
    elif faction == "Воины":
        player["skip_vote"] = False
        return "⚔️ Воины отразили атаку!"
    elif faction == "Фермеры":
        player["luggage"] = "Еда"
        return "🌾 Фермеры нашли еду!"
    elif faction == "Учёные":
        alive = [p for p in game["players"] if p["alive"]]
        if alive:
            target = random.choice([p for p in alive if p["id"] != player["id"]])
            return f"🔬 Учёные раскрыли карту {target['name']}: {target['profession']}"
    elif faction == "Дипломаты":
        player["diplomat_bonus"] = True
        return "🤝 Дипломат получил двойной голос!"
    player["faction_bonus_used"] = True
    return True

