# ----- работа с файлами (статистика, навыки) -----
def load_stats():
    if os.path.exists("stats.json"):
        with open("stats.json", "r", encoding="utf-8") as f:
            return json.load(f)
    return {}

def save_stats(stats):
    with open("stats.json", "w", encoding="utf-8") as f:
        json.dump(stats, f, ensure_ascii=False, indent=2)

def load_skills():
    if os.path.exists("skills.json"):
        with open("skills.json", "r", encoding="utf-8") as f:
            return json.load(f)
    return {}

def save_skills(sk):
    with open("skills.json", "w", encoding="utf-8") as f:
        json.dump(sk, f, ensure_ascii=False, indent=2)

# ----- опыт и прокачка -----
def add_exp(user_id, exp_amount):
    sk = load_skills()
    uid = str(user_id)
    if uid not in sk:
        sk[uid] = {"exp": 0, "lvl": 1}
    sk[uid]["exp"] += exp_amount
    new_lvl = 1 + sk[uid]["exp"] // 100
    if new_lvl > sk[uid]["lvl"]:
        sk[uid]["lvl"] = new_lvl
        save_skills(sk)
        return new_lvl
    save_skills(sk)
    return None

# ----- рейтинг по сезонам -----
def current_season():
    now = datetime.now()
    if now.month in [1,2,3]:
        return "winter2025"
    elif now.month in [4,5,6]:
        return "spring2025"
    else:
        return "autumn2025"

def update_rating(user_id, win):
    season = current_season()
    fname = f"rating_{season}.json"
    if os.path.exists(fname):
        with open(fname, "r") as f:
            rat = json.load(f)
    else:
        rat = {}
    uid = str(user_id)
    if uid not in rat:
        rat[uid] = {"wins": 0, "games": 0, "pts": 1000}
    rat[uid]["games"] += 1
    if win:
        rat[uid]["wins"] += 1
        rat[uid]["pts"] += 25
    else:
        rat[uid]["pts"] -= 15
    with open(fname, "w") as f:
        json.dump(rat, f)

# ----- отправка сообщений (с повтором если упало) -----
def send_msg(chat_id, text, retry=2):
    url = f"https://api.telegram.org/bot{TOKEN}/sendMessage"
    for _ in range(retry):
        try:
            requests.post(url, json={"chat_id": chat_id, "text": text, "parse_mode": "Markdown"}, timeout=5)
            return
        except:
            time.sleep(1)

def send_private(user_id, text):
    send_msg(user_id, text)

# ----- получение обновлений -----
def get_updates(offset):
    url = f"https://api.telegram.org/bot{TOKEN}/getUpdates"
    try:
        r = requests.get(url, params={"offset": offset, "timeout": 10})
        return r.json().get("result", [])
    except:
        return []

