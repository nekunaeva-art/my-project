def start_reveal(chat_id):
    game = active_games.get(chat_id)
    if not game or game["stage"] != "playing":
        return
    alive = [p for p in game["players"] if p["alive"]]
    if not alive:
        end_game(chat_id)
        return
    if game["reveal_idx"] < len(alive):
        p = alive[game["reveal_idx"]]
        game["reveal_idx"] += 1
        send_msg(chat_id, f"📢 {p['name']} показывает карту...")
        threading.Timer(4.0, lambda: start_reveal(chat_id)).start()
    else:
        start_voting(chat_id)

def start_voting(chat_id):
    game = active_games.get(chat_id)
    if not game or game["stage"] != "playing":
        return
    game["stage"] = "voting"
    game["voting_open"] = True
    alive = [p for p in game["players"] if p["alive"] and not p.get("skip_vote")]
    if not alive:
        send_msg(chat_id, "Никто не голосует, случайный вылет")
        all_alive = [p for p in game["players"] if p["alive"]]
        if all_alive:
            victim = random.choice(all_alive)
            victim["alive"] = False
            send_msg(chat_id, f"💀 Выбыл: {victim['name']}")
            finalize_voting(chat_id)
        return
    
    send_msg(chat_id, f"🗳️ Голосование (раунд {game['round']})\nГолосуйте в личке с ботом, 60 секунд.")
    for p in alive:
        if p.get("is_bot"):
            threading.Timer(2.0, lambda: bot_vote(chat_id)).start()
        else:
            others = [t for t in alive if t["id"] != p["id"]]
            keyboard = {
                "inline_keyboard": [
                    [{"text": t["name"], "callback_data": f"vote_{t['id']}|{chat_id}"}]
                    for t in others
                ]
            }
            try:
                requests.post(f"https://api.telegram.org/bot{TOKEN}/sendMessage",
                              json={"chat_id": p["id"], "text": "Кого исключить?",
                                    "reply_markup": keyboard}, timeout=3)
            except:
                pass
    threading.Timer(60.0, lambda: finalize_voting(chat_id)).start()

def bot_vote(chat_id):
    game = active_games.get(chat_id)
    if not game or game["stage"] != "voting" or not game.get("voting_open"):
        return
    alive = [p for p in game["players"] if p["alive"] and not p.get("skip_vote")]
    bot = next((p for p in alive if p.get("is_bot")), None)
    if not bot:
        return
    humans = [p for p in alive if not p.get("is_bot")]
    if humans:
        target = random.choice(humans)
        game["voters"]["bot"] = str(target["id"])

def finalize_voting(chat_id):
    game = active_games.get(chat_id)
    if not game or game["stage"] != "voting":
        return
    game["voting_open"] = False
    alive = [p for p in game["players"] if p["alive"]]
    
    # doomed тикает
    for p in alive:
        if p.get("doomed", 0) > 0:
            p["doomed"] -= 1
            if p["doomed"] == 0:
                p["alive"] = False
                send_msg(chat_id, f"💀 {p['name']} умер от болезни")
                alive = [p for p in game["players"] if p["alive"]]
    
    for p in game["players"]:
        p["skip_vote"] = False
    
    # подсчёт голосов
    votes = {}
    for pid, target_id in game["voters"].items():
        votes[target_id] = votes.get(target_id, 0) + 1
    
    if not votes:
        eliminated = random.choice(alive) if alive else None
    else:
        maxv = max(votes.values())
        candidates = [uid for uid, v in votes.items() if v == maxv]
        elim_id = random.choice(candidates)
        eliminated = next((p for p in alive if str(p["id"]) == elim_id), None)
        if not eliminated and alive:
            eliminated = random.choice(alive)
    
    if eliminated:
        eliminated["alive"] = False
        send_msg(chat_id, f"💀 ВЫБЫЛ: {eliminated['name']}")
    
    alive_after = [p for p in game["players"] if p["alive"]]
    if len(alive_after) <= 1:
        end_game(chat_id)
    else:
        game["round"] += 1
        game["reveal_idx"] = 0
        game["stage"] = "playing"
        game["voters"] = {}
        game["event_triggered"] = False
        send_msg(chat_id, f"🔁 Раунд {game['round']}. Показ карт.")
        start_reveal(chat_id)

def apply_threat_event(chat_id, threat_name, game):
    if game.get("event_triggered"):
        return
    game["event_triggered"] = True
    thr = threats_data.get(threat_name)
    if not thr or not thr.get("events"):
        return
    ev = random.choice(thr["events"])
    send_msg(chat_id, f"⚠️ {ev['text']}")
    if ev["action"] == "poison":
        alive = [p for p in game["players"] if p["alive"]]
        if alive:
            victim = random.choice(alive)
            victim["doomed"] = 2
            send_msg(chat_id, f"☢️ {victim['name']} заболел")
    elif ev["action"] == "crack":
        repair = next((p for p in game["players"] if p["prof"] in ["Инженер","Строитель"] and p["alive"]), None)
        if not repair:
            alive = [p for p in game["players"] if p["alive"]]
            if alive:
                victim = random.choice(alive)
                victim["alive"] = False
                send_msg(chat_id, f"💀 {victim['name']} погиб")
    elif ev["action"] == "bite":
        alive = [p for p in game["players"] if p["alive"]]
        if alive:
            victim = random.choice(alive)
            victim["doomed"] = 2
            send_msg(chat_id, f"🧟 {victim['name']} укушен")
    elif ev["action"] == "horde":
        alive = [p for p in game["players"] if p["alive"]]
        if alive:
            victim = random.choice(alive)
            victim["alive"] = False
            send_msg(chat_id, f"🧟 {victim['name']} погиб")

def end_game(chat_id):
    game = active_games.get(chat_id)
    if not game:
        return
    alive = [p for p in game["players"] if p["alive"]]
    winner = alive[0] if alive else None
    if winner:
        msg = f"🏆 ПОБЕДИТЕЛЬ: {winner['name']}!\n"
        threat = game["threat"]
        thr_info = threats_data.get(threat, {})
        survived = False
        if winner["prof"] in thr_info.get("profs", []):
            survived = True
        elif winner["luggage"] in thr_info.get("items", []):
            survived = True
        
        if survived:
            msg += "✅ Ты выжил! +100 опыта"
            add_exp(winner["id"], 100)
            update_rating(winner["id"], True)
        else:
            msg += "❌ Не справился... +50 опыта"
            add_exp(winner["id"], 50)
            update_rating(winner["id"], False)
        
        # достижения (упрощённо)
        ach = []
        if winner.get("first_game_done"):
            ach.append("first_game")
        else:
            winner["first_game_done"] = True
            ach.append("first_game")
        if ach:
            msg += "\n🎖️ Достижения: " + ", ".join([achievements_dict.get(a, a) for a in ach])
    else:
        msg = "💀 Все погибли."
    
    send_msg(chat_id, msg)
    del active_games[chat_id]

# ----- обработка команд статистики, крафта и т.п. -----
def handle_stats(uid, uname):
    st = load_stats()
    uid_s = str(uid)
    if uid_s not in st:
        send_private(uid, "Нет статистики. Сыграйте!")
        return
    s = st[uid_s]
    send_private(uid, f"📊 {uname}\nИгр: {s.get('games',0)}\nПобед: {s.get('wins',0)}")

def handle_craft(chat_id, uid, text):
    parts = text.split()
    if len(parts) < 3:
        send_private(uid, "Надо: /craft предмет1 предмет2")
        return
    it1, it2 = parts[1], parts[2]
    game = None
    for g in active_games.values():
        if any(p["id"] == uid for p in g["players"]):
            game = g
            break
    if not game:
        send_private(uid, "Вы не в игре")
        return
    player = next((p for p in game["players"] if p["id"] == uid), None)
    if not player or player.get("is_bot"):
        send_private(uid, "Нельзя")
        return
    if player["luggage"] not in [it1, it2]:
        send_private(uid, f"У вас нет {it1} или {it2}. У вас: {player['luggage']}")
        return
    key = tuple(sorted([it1, it2]))
    if key in craft_recipes:
        rec = craft_recipes[key]
        player["luggage"] = rec["result"]
        add_exp(uid, rec["val"] * 10)
        send_private(uid, f"✅ Скрафтили {rec['result']}!")
        send_msg(game["chat_id"], f"🔨 {player['name']} скрафтил {rec['result']}")
    else:
        send_private(uid, "Не крафтится")

# ----- основной цикл -----
offset = 0
print("Бот запущен. Жду 'хочу играть в бункер' в группе")

while True:
    try:
        updates = get_updates(offset)
        for upd in updates:
            offset = upd["update_id"] + 1
            
            if "callback_query" in upd:
                cb = upd["callback_query"]
                data = cb.get("data", "")
                user_id = cb["from"]["id"]
                try:
                    requests.post(f"https://api.telegram.org/bot{TOKEN}/answerCallbackQuery",
                                  json={"callback_query_id": cb["id"]}, timeout=2)
                except:
                    pass
                if data.startswith("vote_"):
                    parts = data.split("|")
                    if len(parts) == 2:
                        vote_part, group_chat = parts
                        target_id = vote_part.replace("vote_", "")
                        group_chat_id = int(group_chat)
                        game = active_games.get(group_chat_id)
                        if game and game.get("voting_open"):
                            voter = next((p for p in game["players"] if p["id"] == user_id), None)
                            if voter and not voter.get("is_bot") and voter["alive"] and not voter.get("skip_vote"):
                                game["voters"][user_id] = str(target_id)
                                send_private(user_id, f"Голос отдан за {target_id}")
                continue
            
            if "message" not in upd:
                continue
            msg = upd["message"]
            chat_id = msg["chat"]["id"]
            user_id = msg["from"]["id"]
            user_name = get_name(msg["from"])
            text = msg.get("text", "").lower()
            
            # личка
            if chat_id == user_id:
                if text == "/start":
                    send_msg(chat_id, "Бункер бот. Добавь в группу и напиши 'хочу играть в бункер'")
                elif text.startswith("/stats"):
                    handle_stats(user_id, user_name)
                elif text.startswith("/craft"):
                    handle_craft(chat_id, user_id, msg.get("text", ""))
                else:
                    send_msg(chat_id, "Команды: /stats, /craft предмет1 предмет2")
                continue
            
            # группа
            print(f"[{chat_id}] {user_name}: {text}")
            if "хочу играть в бункер" in text or "играть в бункер" in text:
                if chat_id in active_games:
                    send_msg(chat_id, "Игра уже идёт!")
                    continue
                # проверка на сценарий
                scenario = None
                for sc in scenarios_dict.keys():
                    if sc.lower() in text:
                        scenario = sc
                        break
                send_msg(chat_id, f"🎮 {user_name} начинает дуэль!")
                start_duel(chat_id, user_id, user_name, scenario)
            elif text == "/stop" and chat_id in active_games:
                del active_games[chat_id]
                send_msg(chat_id, "Игра прервана")
    except Exception as e:
        print("Ошибка:", e)
    time.sleep(1)